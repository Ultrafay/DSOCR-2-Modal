# ── OpenAI ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Modal OCR ───────────────────────────────────────
MODAL_OCR_URL=https://ultrafay--deepseek-ocr-ocrmodel-ocr.modal.run
MODAL_PROXY_TOKEN_ID=wk-...
MODAL_PROXY_TOKEN_SECRET=ws-...

# ── Google Sheets ───────────────────────────────────
GOOGLE_SHEET_ID=your-spreadsheet-id
# Path to service account JSON file (local dev)
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials/service_account.json
# OR: paste the full JSON content here (production / Railway)
# GOOGLE_SERVICE_ACCOUNT_CONTENT={"type":"service_account",...}

# ── GL Classifier (optional) ────────────────────────
# Only needed if you want sheet-driven GL classification.
# Leave blank to use the extractor's built-in GL classification only.
# GL_MAPPING_SHEET_ID=your-gl-mapping-sheet-id
